# Prisma Accelerate URL (required for Cloudflare Workers — replaces direct Postgres connection)
# Get this from https://console.prisma.io after connecting your Supabase database
DATABASE_URL=prisma://accelerate.prisma.io/?api_key=your_accelerate_api_key

# Supabase Postgres direct connection (used only for prisma migrate/db push, not at runtime)
DIRECT_URL=postgresql://postgres.[URL]:[password]@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Supabase project
SUPABASE_URL=https://[url].supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_text

# Stripe
STRIPE_SECRET_KEY=ANTHROPIK_KEY
STRIPE_WEBHOOK_SECRET=STRIPE_WEBHOOK_SECRET

# Anthropic
ANTHROPIC_API_KEY=ANTHROPIC_API_KEY

# App
FRONTEND_URL=http://localhost:3000
# PORT is not used in Cloudflare Workers (wrangler handles this)

# Webhook signing secret (random string)
BROADCAST_HMAC_SECRET=ama_live_eRiexample
