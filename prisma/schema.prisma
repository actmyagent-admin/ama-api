generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  BUYER
  AGENT_LISTER
}

enum ContactMessageStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ContactPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ContractStatus {
  DRAFT
  SIGNED_BUYER
  SIGNED_AGENT
  ACTIVE
  COMPLETED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  ESCROWED
  RELEASED
  REFUNDED
}

enum DeliveryStatus {
  SUBMITTED
  APPROVED
  DISPUTED
}

enum AiAuditLogType {
  JOB_CATEGORIZATION
  CONTRACT_GENERATION
}

enum AiAuditLogStatus {
  SUCCESS
  PARSE_ERROR
  API_ERROR
}

model User {
  id             String        @id @default(uuid()) @db.Uuid
  supabaseId     String        @unique @db.Uuid
  email          String        @unique
  userName       String        @unique
  name           String?
  mainPic        String?
  coverPic       String?
  roles          Role[]
  stripeAccountId String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  agentProfile   AgentProfile?
  jobs           Job[]
  contracts      Contract[]
  messages       Message[]
  aiAuditLogs    AiAuditLog[]
}

model AgentProfile {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @unique @db.Uuid
  user          User       @relation(fields: [userId], references: [id])
  name          String
  slug          String     @unique
  description   String
  categories    Category[]
  priceFrom     Float
  priceTo       Float
  currency      String     @default("USD")
  mainPic       String?
  coverPic      String?
  webhookUrl    String
  // API key: only the bcrypt hash is stored; raw key shown once at registration
  apiKeyHash    String?
  // First 8 chars of raw key stored unencrypted for fast lookup (filter by prefix, then bcrypt compare)
  apiKeyPrefix  String?
  isVerified    Boolean    @default(false)
  isActive      Boolean    @default(true)
  avgRating     Float?
  totalJobs     Int        @default(0)
  createdAt     DateTime   @default(now())
  proposals     Proposal[]
  contracts     Contract[]
}

model Job {
  id          String     @id @default(uuid()) @db.Uuid
  buyerId     String     @db.Uuid
  buyer       User       @relation(fields: [buyerId], references: [id])
  title       String
  description String
  category    String
  budget      Float?
  currency    String     @default("USD")
  deadline    DateTime?
  status      JobStatus  @default(OPEN)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  proposals   Proposal[]
  contract    Contract?
  aiAuditLogs AiAuditLog[]
}

model Proposal {
  id             String         @id @default(uuid()) @db.Uuid
  jobId          String         @db.Uuid
  job            Job            @relation(fields: [jobId], references: [id])
  agentProfileId String         @db.Uuid
  agentProfile   AgentProfile   @relation(fields: [agentProfileId], references: [id])
  message        String
  price          Float
  currency       String         @default("USD")
  estimatedDays  Int
  status         ProposalStatus @default(PENDING)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  contract       Contract?
  aiAuditLogs    AiAuditLog[]
}

model Contract {
  id             String         @id @default(uuid()) @db.Uuid
  jobId          String         @unique @db.Uuid
  job            Job            @relation(fields: [jobId], references: [id])
  proposalId     String         @unique @db.Uuid
  proposal       Proposal       @relation(fields: [proposalId], references: [id])
  buyerId        String         @db.Uuid
  buyer          User           @relation(fields: [buyerId], references: [id])
  agentProfileId String         @db.Uuid
  agentProfile   AgentProfile   @relation(fields: [agentProfileId], references: [id])
  scope          String
  deliverables   String
  price          Float
  currency       String         @default("USD")
  deadline       DateTime
  status         ContractStatus @default(DRAFT)
  buyerSignedAt  DateTime?
  agentSignedAt  DateTime?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  messages       Message[]
  payment        Payment?
  delivery       Delivery?
  aiAuditLogs    AiAuditLog[]
}

model Message {
  id         String    @id @default(uuid()) @db.Uuid
  contractId String    @db.Uuid
  contract   Contract  @relation(fields: [contractId], references: [id])
  senderId   String    @db.Uuid
  sender     User      @relation(fields: [senderId], references: [id])
  senderRole Role
  content    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([contractId, createdAt])
}

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  contractId            String        @unique @db.Uuid
  contract              Contract      @relation(fields: [contractId], references: [id])
  stripePaymentIntentId String        @unique
  amount                Float
  currency              String        @default("USD")
  status                PaymentStatus @default(PENDING)
  createdAt             DateTime      @default(now())
}

model Delivery {
  id          String         @id @default(uuid()) @db.Uuid
  contractId  String         @unique @db.Uuid
  contract    Contract       @relation(fields: [contractId], references: [id])
  description String
  fileUrls    String[]
  status      DeliveryStatus @default(SUBMITTED)
  submittedAt DateTime       @default(now())
}

model Category {
  id        String         @id @default(uuid()) @db.Uuid
  name      String
  slug      String         @unique
  mainPic   String?
  coverPic  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  agents    AgentProfile[]
}

model AiAuditLog {
  id                String           @id @default(uuid()) @db.Uuid
  type              AiAuditLogType
  status            AiAuditLogStatus @default(SUCCESS)
  model             String
  inputPrompt       String
  rawOutput         String
  parsedOutputJson  Json?
  inputTokens       Int?
  outputTokens      Int?
  durationMs        Int?
  errorMessage      String?
  // Context references — optional because job may not yet exist when categorization runs,
  // and contract may not yet exist when generation runs; populated after DB writes complete.
  jobId             String?          @db.Uuid
  job               Job?             @relation(fields: [jobId], references: [id])
  proposalId        String?          @db.Uuid
  proposal          Proposal?        @relation(fields: [proposalId], references: [id])
  contractId        String?          @db.Uuid
  contract          Contract?        @relation(fields: [contractId], references: [id])
  triggeredByUserId String?          @db.Uuid
  triggeredByUser   User?            @relation(fields: [triggeredByUserId], references: [id])
  createdAt         DateTime         @default(now())
}

model ContactMessage {
  id          Int                  @id @default(autoincrement())
  name        String
  email       String
  phone       String?
  subject     String
  message     String
  source      String?
  status      ContactMessageStatus @default(NEW)
  priority    ContactPriority      @default(NORMAL)
  respondedAt DateTime?
  ipAddress   String?              @db.VarChar(45)
  userAgent   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}
