generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  BUYER
  AGENT_LISTER
}

enum ContactMessageStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ContactPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ContractStatus {
  DRAFT
  SIGNED_BUYER
  SIGNED_AGENT
  ACTIVE
  COMPLETED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  ESCROWED
  RELEASED
  REFUNDED
}

enum DeliveryStatus {
  SUBMITTED
  APPROVED
  DISPUTED
}

enum AiAuditLogType {
  JOB_CATEGORIZATION
  CONTRACT_GENERATION
}

enum AgentErrorStep {
  // Inbound webhook events (our system → agent)
  JOB_RECEIVED        // Agent received a job-broadcast webhook
  MESSAGE_RECEIVED    // Agent received a message webhook
  // Outbound API calls (agent → our system)
  PROPOSAL_SUBMISSION // Agent tried to POST a proposal
  MESSAGE_SEND        // Agent tried to POST a message
  CONTRACT_REVIEW     // Agent tried to sign / query a contract
  DELIVERY_SUBMISSION // Agent tried to submit a delivery
  AUTHENTICATION      // API-key auth or signature verification failed
  OTHER               // Anything that doesn't fit the above
}

enum AiAuditLogStatus {
  SUCCESS
  PARSE_ERROR
  API_ERROR
}

enum BroadcastStatus {
  SUCCESS    // 2xx from agent webhook
  HTTP_ERROR // non-2xx response received
  TIMEOUT    // fetch aborted after 5 s
  FAILED     // network/fetch error
}

model User {
  id                   String                @id @default(uuid()) @db.Uuid
  supabaseId           String                @unique @db.Uuid
  email                String                @unique
  userName             String                @unique
  name                 String?
  mainPic              String?
  coverPic             String?
  bioBrief             String?
  bioDetail            String?
  instagram            String?
  facebook             String?
  x                    String?
  discord              String?
  roles                Role[]
  stripeAccountId      String?
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  agentProfiles        AgentProfile[]
  jobs                 Job[]
  contracts            Contract[]
  messages             Message[]
  aiAuditLogs          AiAuditLog[]
  stripeConnectAccount StripeConnectAccount?
  ledgerEntries        LedgerEntry[]
  payouts              Payout[]
}

model AgentProfile {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @db.Uuid
  user          User       @relation(fields: [userId], references: [id])
  name          String
  slug          String     @unique
  description   String
  categories    Category[]
  priceFrom     Float
  priceTo       Float
  currency      String     @default("USD")
  mainPic       String?
  coverPic      String?
  webhookUrl    String
  // API key: only the bcrypt hash is stored; raw key shown once at registration
  apiKeyHash    String?
  // First 8 chars of raw key stored unencrypted for fast lookup (filter by prefix, then bcrypt compare)
  apiKeyPrefix  String?
  isVerified    Boolean    @default(false)
  isActive      Boolean    @default(true)
  avgRating     Float?
  totalJobs     Int        @default(0)
  createdAt     DateTime   @default(now())
  modifiedAt    DateTime   @default(now()) @updatedAt
  proposals      Proposal[]
  contracts      Contract[]
  errorLogs      AgentErrorLog[]
  broadcastLogs  BroadcastLog[]

  @@index([userId])
}

model Job {
  id          String     @id @default(uuid()) @db.Uuid
  buyerId     String     @db.Uuid
  buyer       User       @relation(fields: [buyerId], references: [id])
  title       String
  description String
  category    String
  budget      Float?
  currency    String     @default("USD")
  deadline    DateTime?
  status      JobStatus  @default(OPEN)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  proposals      Proposal[]
  contract       Contract?
  aiAuditLogs    AiAuditLog[]
  errorLogs      AgentErrorLog[]
  broadcastLogs  BroadcastLog[]
}

model Proposal {
  id             String         @id @default(uuid()) @db.Uuid
  jobId          String         @db.Uuid
  job            Job            @relation(fields: [jobId], references: [id])
  agentProfileId String         @db.Uuid
  agentProfile   AgentProfile   @relation(fields: [agentProfileId], references: [id])
  message        String
  price          Float
  currency       String         @default("USD")
  estimatedDays  Int
  status         ProposalStatus @default(PENDING)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  contract       Contract?
  aiAuditLogs    AiAuditLog[]
  errorLogs      AgentErrorLog[]
}

model Contract {
  id             String         @id @default(uuid()) @db.Uuid
  jobId          String         @unique @db.Uuid
  job            Job            @relation(fields: [jobId], references: [id])
  proposalId     String         @unique @db.Uuid
  proposal       Proposal       @relation(fields: [proposalId], references: [id])
  buyerId        String         @db.Uuid
  buyer          User           @relation(fields: [buyerId], references: [id])
  agentProfileId String         @db.Uuid
  agentProfile   AgentProfile   @relation(fields: [agentProfileId], references: [id])
  scope          String
  deliverables   String
  price          Float
  currency       String         @default("USD")
  deadline       DateTime
  status         ContractStatus @default(DRAFT)
  buyerSignedAt  DateTime?
  agentSignedAt  DateTime?
  isActive       Boolean        @default(true)
  autoReleaseAt  DateTime?      // set when delivery submitted, cleared on buyer response
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  messages       Message[]
  payment        Payment?
  delivery       Delivery?
  aiAuditLogs    AiAuditLog[]
  errorLogs      AgentErrorLog[]
  ledgerEntries  LedgerEntry[]
}

model Message {
  id         String    @id @default(uuid()) @db.Uuid
  contractId String    @db.Uuid
  contract   Contract  @relation(fields: [contractId], references: [id])
  senderId   String    @db.Uuid
  sender     User      @relation(fields: [senderId], references: [id])
  senderRole Role
  content    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([contractId, createdAt])
}

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  contractId            String        @unique @db.Uuid
  contract              Contract      @relation(fields: [contractId], references: [id])
  stripePaymentIntentId String        @unique
  stripeTransferId      String?
  stripeRefundId        String?
  // Stored in cents (integers) — never use floats for money
  amountTotal           Int           @default(0)
  amountPlatformFee     Int           @default(0)
  amountAgentReceives   Int           @default(0)
  currency              String        @default("usd")
  // Snapshot of agent's Stripe account at payment time
  agentStripeAccountId  String        @default("")
  status                PaymentStatus @default(PENDING)
  capturedAt            DateTime?
  releasedAt            DateTime?
  refundedAt            DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  ledgerEntries         LedgerEntry[]
}

model Delivery {
  id               String         @id @default(uuid()) @db.Uuid
  contractId       String         @unique @db.Uuid
  contract         Contract       @relation(fields: [contractId], references: [id])
  description      String
  // S3 keys (not full URLs — signed URLs generated on demand)
  fileKeys         String[]
  fileNames        String[]       // original filenames for display
  fileSizes        Int[]          // bytes
  status           DeliveryStatus @default(SUBMITTED)
  submittedAt      DateTime       @default(now())
  reviewDeadline   DateTime?      // submittedAt + 5 days
  approvedAt       DateTime?
  disputedAt       DateTime?
  disputeReason    String?
  autoApproveJobId String?        // reserved for future job queue integration
}

model Category {
  id        String         @id @default(uuid()) @db.Uuid
  name      String
  slug      String         @unique
  mainPic   String?
  coverPic  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  agents    AgentProfile[]
}

model AiAuditLog {
  id                String           @id @default(uuid()) @db.Uuid
  type              AiAuditLogType
  status            AiAuditLogStatus @default(SUCCESS)
  model             String
  inputPrompt       String
  rawOutput         String
  parsedOutputJson  Json?
  inputTokens       Int?
  outputTokens      Int?
  durationMs        Int?
  errorMessage      String?
  // Context references — optional because job may not yet exist when categorization runs,
  // and contract may not yet exist when generation runs; populated after DB writes complete.
  jobId             String?          @db.Uuid
  job               Job?             @relation(fields: [jobId], references: [id])
  proposalId        String?          @db.Uuid
  proposal          Proposal?        @relation(fields: [proposalId], references: [id])
  contractId        String?          @db.Uuid
  contract          Contract?        @relation(fields: [contractId], references: [id])
  triggeredByUserId String?          @db.Uuid
  triggeredByUser   User?            @relation(fields: [triggeredByUserId], references: [id])
  createdAt         DateTime         @default(now())
}

model AgentErrorLog {
  id             String         @id @default(uuid()) @db.Uuid
  agentProfileId String         @db.Uuid
  agentProfile   AgentProfile   @relation(fields: [agentProfileId], references: [id])
  step           AgentErrorStep
  // Short machine-readable code the agent assigns, e.g. "TIMEOUT", "PARSE_ERROR", "HTTP_403"
  errorCode      String?
  // Human-readable description of what went wrong
  errorMessage   String
  // HTTP status the agent received from our API, when applicable
  httpStatus     Int?
  // Sanitised copy of the payload the agent tried to send us
  requestPayload Json?
  // Raw response body or error object the agent received
  responseBody   String?
  // Optional context — which job/proposal/contract was being worked on
  jobId          String?        @db.Uuid
  job            Job?           @relation(fields: [jobId], references: [id])
  proposalId     String?        @db.Uuid
  proposal       Proposal?      @relation(fields: [proposalId], references: [id])
  contractId     String?        @db.Uuid
  contract       Contract?      @relation(fields: [contractId], references: [id])
  // Free-form bag for any additional diagnostic context
  metadata       Json?
  createdAt      DateTime       @default(now())

  @@index([agentProfileId, createdAt])
  @@index([jobId])
  @@index([contractId])
}

model ContactMessage {
  id          Int                  @id @default(autoincrement())
  name        String
  email       String
  phone       String?
  subject     String
  message     String
  source      String?
  status      ContactMessageStatus @default(NEW)
  priority    ContactPriority      @default(NORMAL)
  respondedAt DateTime?
  ipAddress   String?              @db.VarChar(45)
  userAgent   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

// Stripe Connect account details for AGENT_LISTER users
model StripeConnectAccount {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @unique @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeAccountId       String    @unique
  chargesEnabled        Boolean   @default(false)
  payoutsEnabled        Boolean   @default(false)
  detailsSubmitted      Boolean   @default(false)
  accountType           String    @default("standard")
  country               String?
  defaultCurrency       String?
  onboardingCompletedAt DateTime?
  lastVerifiedAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// Platform financial ledger — every money movement as a line item
model LedgerEntry {
  id              String    @id @default(uuid()) @db.Uuid
  paymentId       String    @db.Uuid
  payment         Payment   @relation(fields: [paymentId], references: [id])
  contractId      String    @db.Uuid
  contract        Contract  @relation(fields: [contractId], references: [id])
  userId          String?   @db.Uuid
  user            User?     @relation(fields: [userId], references: [id])
  // 'buyer' | 'agent' | 'platform'
  partyType       String
  // 'buyer_charge' | 'agent_payout' | 'platform_fee' | 'buyer_refund' | 'agent_clawback' | 'authorization_hold' | 'authorization_release'
  entryType       String
  // Positive = money in, negative = money out (from the perspective of partyType)
  amountCents     Int
  currency        String    @default("usd")
  stripeReference String?
  // 'pending' | 'completed' | 'failed' | 'reversed'
  status          String    @default("pending")
  description     String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  settledAt       DateTime?

  @@index([paymentId])
  @@index([userId])
  @@index([contractId])
  @@index([entryType])
  @@index([createdAt])
}

// Tracks individual payouts sent to agent listers
model Payout {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  user            User      @relation(fields: [userId], references: [id])
  stripeAccountId String
  stripePayoutId  String    @unique
  amountCents     Int
  currency        String    @default("usd")
  // 'pending' | 'paid' | 'failed' | 'canceled'
  status          String    @default("pending")
  arrivalDate     DateTime? @db.Date
  failureMessage  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

// Daily platform revenue rollup — populated by a nightly job
model PlatformRevenue {
  id             String   @id @default(uuid()) @db.Uuid
  date           DateTime @unique @db.Date
  grossVolumeGMV Int      @default(0)
  platformFees   Int      @default(0)
  refundsIssued  Int      @default(0)
  netRevenue     Int      @default(0)
  completedJobs  Int      @default(0)
  disputedJobs   Int      @default(0)
  refundedJobs   Int      @default(0)
  currency       String   @default("usd")
  createdAt      DateTime @default(now())
}

// One row per agent per job broadcast — full audit trail of every webhook fire
model BroadcastLog {
  id             String          @id @default(uuid()) @db.Uuid
  jobId          String          @db.Uuid
  job            Job             @relation(fields: [jobId], references: [id])
  agentProfileId String          @db.Uuid
  agentProfile   AgentProfile    @relation(fields: [agentProfileId], references: [id])
  // Snapshot of the URL used — preserved even if agent later changes it
  webhookUrl     String
  status         BroadcastStatus
  // HTTP response code received from the agent webhook (null on timeout/network error)
  httpStatus     Int?
  // First 2 KB of response body — enough to diagnose errors without unbounded storage
  responseBody   String?
  // Error message from fetch/timeout (null on success)
  errorMessage   String?
  // Round-trip latency in ms (null if request never completed)
  durationMs     Int?
  // Number of agents that were matched and targeted in the same broadcast round
  totalAgentsInBatch Int?
  attemptedAt    DateTime        @default(now())
  // When the webhook responded (null = no response yet / timed out)
  respondedAt    DateTime?

  @@index([jobId])
  @@index([agentProfileId])
  @@index([status])
  @@index([attemptedAt])
}
